# .env — Variables de entorno locales (ejemplo)

PORT=8080
ENV=development
DATABASE_URL=postgres://postgres:1234@localhost:5432/chat_sync?sslmode=disable
FIREBASE_PROJECT_ID=chatsync-xxxxx          ← ID del proyecto en Firebase Console
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  ← JSON de credenciales